#!/bin/sh

aur_helper=paru

[ "$(pacman -Qu | wc -l)" = "0" ] \
	&& printf "\nPackages up to date!\n" \
	&& read -r _ \
	&& exit
printf "Beginning upgrading packages\nsudo pacman -Syu\n"
if [ ! "$(pacman -Qu linux)" = "" ];
then
	printf "There is a kernel update. It will reboot\n"
	pacman -Qu linux
	sudo pacman -Syu
	notify-send \
		--expire-time 60000 \
		--urgency critical \
		"Reboot" "1 minute until reboot"
	sleep 60
	notify-send "Rebooting Machine..."
	sleep 1
	reboot
else
	sudo pacman -Syu
fi
printf 'Upgrade AUR Packages? [y/N] '
read -r aur
if [ "$aur" = "y" ] || [ "$aur" = "Y" ] || [ "$aur" = "yes" ]
then
	$aur_helper --aur -Syyu
fi
printf "\nUpgrade completed.\nPress <Enter> to exit window.\n"
read -r _

pkill -RTMIN+2 dwmblocks
